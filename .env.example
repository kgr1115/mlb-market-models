# Copy this file to .env (which is gitignored) and fill in real values.
#
# The Odds API key — https://the-odds-api.com/  (free tier: 500 credits/month).
# Used by data/odds_theoddsapi.py as the DraftKings odds source.
# If unset, the app falls back to the Playwright DK scraper.
ODDS_API_KEY=APIKEYHERE

# Optional overrides:
# BBP_CACHE_PATH=bbp_cache.sqlite        # SQLite odds cache path
# BBP_FANDUEL_STATE=nj                    # state code for FanDuel scraper
# BBP_DISABLE_POLLER=0                    # set to 1 to skip the background poller
# HOST=0.0.0.0                            # bind interface
# PORT=8000                               # web server port
# OPEN_BROWSER=1                          # auto-open browser on start
